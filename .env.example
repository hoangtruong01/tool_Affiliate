# ============================================
# AI Video Affiliate Tool — Environment Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === Database ===
POSTGRES_USER=affiliate_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=affiliate_tool
DATABASE_URL=postgresql+asyncpg://affiliate_user:changeme_strong_password@postgres:5432/affiliate_tool

# === Redis ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === Auth ===
JWT_SECRET_KEY=changeme_jwt_secret_256bit_minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme_admin_password

# === AI Providers ===
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-key

# === n8n ===
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n
N8N_WEBHOOK_URL=http://n8n:5678

# === App ===
APP_ENV=development
BACKEND_URL=http://api:8000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
MEDIA_DIR=/app/media
MAX_UPLOAD_SIZE_MB=100
FFMPEG_PATH=/usr/bin/ffmpeg

# === TikTok (Future) ===
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# === Shopee (Future) ===
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
